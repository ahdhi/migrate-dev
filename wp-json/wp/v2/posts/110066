;visible&#8221; overlay_strength=&#8221;0.3&#8243; gradient_direction=&#8221;left_to_right&#8221; shape_divider_position=&#8221;bottom&#8221; bg_image_animation=&#8221;none&#8221;][vc_column column_padding=&#8221;no-extra-padding&#8221; column_padding_tablet=&#8221;inherit&#8221; column_padding_phone=&#8221;inherit&#8221; column_padding_position=&#8221;all&#8221; column_element_spacing=&#8221;default&#8221; background_color_opacity=&#8221;1&#8243; background_hover_color_opacity=&#8221;1&#8243; column_shadow=&#8221;none&#8221;&#8230;<\/p>\n","protected":false},"author":1,"featured_media":110070,"comment_status":"closed","ping_status":"closed","sticky":false,"template":"","format":"standard","meta":{"_acf_changed":false,"footnotes":""},"categories":[121,129],"tags":[],"class_list":{"0":"post-110066","1":"post","2":"type-post","3":"status-publish","4":"format-standard","5":"has-post-thumbnail","7":"category-regional","8":"category-skilled-visa"},"acf":[],"_links":{"self":[{"href":"https:\/\/www.anzscosearch.com\/wp-json\/wp\/v2\/posts\/110066","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/www.anzscosearch.com\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"https:\/\/www.anzscosearch.com\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"https:\/\/www.anzscosearch.com\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/www.anzscosearch.com\/wp-json\/wp\/v2\/comments?post=110066"}],"version-history":[{"count":6,"href":"https:\/\/www.anzscosearch.com\/wp-json\/wp\/v2\/posts\/110066\/revisions"}],"predecessor-version":[{"id":110168,"href":"https:\/\/www.anzscosearch.com\/wp-json\/wp\/v2\/posts\/110066\/revisions\/110168"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/www.anzscosearch.com\/wp-json\/wp\/v2\/media\/110070"}],"wp:attachment":[{"href":"https:\/\/www.anzscosearch.com\/wp-json\/wp\/v2\/media?parent=110066"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/www.anzscose