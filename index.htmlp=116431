	<div  class="vc_col-sm-8 wpb_column column_container vc_column_container col left_padding_desktop_2vw flex_gap_desktop_10px "  data-padding-pos="all" data-has-bg-color="false" data-bg-color="" data-bg-opacity="1" data-animation="" data-delay="0" >
