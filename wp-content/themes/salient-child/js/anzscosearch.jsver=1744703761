function before_1(){
	jQuery('#search_group').attr('disabled', 'disabled');
	jQuery('#spin').toggleClass('fa-search fa-circle-notch fa-spin');
}

function complete_1(){
	jQuery('#search_group').removeAttr('disabled');
	jQuery('#spin').toggleClass('fa-circle-notch fa-spin fa-search');
}
