// timeline
function drawChart1() {
  var container = document.getElementById('timeline-skilled');
  var chart = new google.visualization.Timeline(container);
  var dataTable = new google.visualization.DataTable();

  dataTable.addColumn({ type: 'string', id: 'Role' });
  dataTable.addColumn({ type: 'string', id: 'Name' });
  dataTable.addColumn({ type: 'date', id: 'Start' });
  dataTable.addColumn({ type: 'date', id: 'End' });
  dataTable.addRows([
    [ 'Program 2019-20', 'Skilled Migration Program 2019-20', new Date(2019, 6, 1), new Date(2020, 5, 30) ],
    [ 'Skilled Regional', 'Skilled Work Regional (Subclass 489) closed', new Date(2019, 6, 1), new Date(2019, 10, 15) ],
    [ 'Skilled Regional', 'Skilled Regional (Subclass 491 & 494) starts', new Date(2019, 10, 16), new Date(2020, 5, 30) ],
    [ 'Covid-19 Pandemic', 'Covid 19 - Travel ban', new Date(2020, 2, 20), new Date(2020, 5, 30) ]
  ]);

  var options = {
    timeline: { groupByRowLabel: true },
    colors: ['#3366CC', '#DC3912', '#109619' , '#F5B400']
  };

  chart.draw(dataTable, options);
}

// total Nominations by State & Territory Governments
