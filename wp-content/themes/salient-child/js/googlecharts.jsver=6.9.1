    ['Skilled Work Regional 491', 5739],
    ['Skilled Regional 489', 3946],
    ['Business Innovation and Investment 188', 3612],
    ['Business Talent Visa 132', 793]
  ]);

  var options = {
    title: 'State & Territory Nominated',
    is3D: true,
    height: 400
  };

  var chart = new google.visualization.PieChart(document.getElementById('piechart_3d'));
  chart.draw(data, options);
}

